{
  "manifest_version": 2,
  "name": "URL to File",
  "version": "1.0",
  "description": "Writes the URL of the currently loaded tab to a file on local disk.",
  "permissions": ["tabs", "downloads", "storage"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  }
}
